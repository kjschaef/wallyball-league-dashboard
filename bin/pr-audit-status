#!/usr/bin/env bash
set -euo pipefail

if [ -z "${1:-}" ]; then
  echo "Usage: $0 <pr-number>" >&2
  exit 1
fi

PR_NUMBER="$1"

# Get status check rollup
ROLLUP=$(gh pr view "$PR_NUMBER" --json statusCheckRollup --jq '.statusCheckRollup // []')

# Check if there are any failures (conclusion is FAILURE/CANCELLED/TIMED_OUT or state is FAILURE/ERROR)
FAILURES=$(echo "$ROLLUP" | jq -c '.[] | select((.conclusion == "FAILURE" or .conclusion == "CANCELLED" or .conclusion == "TIMED_OUT" or .conclusion == "ACTION_REQUIRED" or .conclusion == "STALE") or (.state == "FAILURE" or .state == "ERROR"))')

# Check if there are any pending/in-progress checks (status is not COMPLETED for CheckRun, or state is PENDING for StatusContext)
PENDING=$(echo "$ROLLUP" | jq -c '.[] | select((.__typename == "CheckRun" and .status != "COMPLETED") or (.__typename == "StatusContext" and .state == "PENDING"))')

if [ -n "$FAILURES" ]; then
  echo "FAILURES:"
  echo "$FAILURES" | jq -r '"- " + (.name // .context) + " (" + (.conclusion // .state) + ")"'
  exit 1
elif [ -n "$PENDING" ]; then
  echo "PENDING:"
  echo "$PENDING" | jq -r '"- " + (.name // .context) + " (" + (.status // .state) + ")"'
  exit 2
else
  echo "SUCCESS"
fi
